# 1. Enforce linting ONLY on staged TS/TSX files
STAGED_TS_FILES=$(git diff --cached --name-only | grep -E '\.(ts|tsx)$' || true)

if [ -n "$STAGED_TS_FILES" ]; then
  echo "TypeScript files staged. Running linter on modified files..."
  
  # 如果專案之後有安裝 eslint，可以取消註解下方這行來進行局部檢查：
  # npx eslint $STAGED_TS_FILES
  # if [ $? -ne 0 ]; then
  #   echo "❌ Lint failed on staged files. Please fix before committing."
  #   exit 1
  # fi
  
  # 目前使用 tsc --noEmit 進行全域型別檢查
  echo "Running global type check..."
  npm run lint
  if [ $? -ne 0 ]; then
    echo "❌ Type check failed. Please fix before committing."
    exit 1
  fi
else
  echo "No TypeScript files staged, skipping linter."
fi

# 2. Block restricted files from entering version control
echo "Checking for restricted files..."
RESTRICTED_FILES=".agents/AgentMap.yaml .agents/HumanMap.md .agents/STATE.md task.md pr_review.md"
for file in $RESTRICTED_FILES; do
  if git diff --cached --name-only | grep -q "$file"; then
    echo "❌ ERROR: You are trying to commit a restricted file: $file"
    echo "As per AGENTS.md, these files are local-only and MUST NOT enter version control."
    echo "To fix this, run: git reset HEAD $file"
    exit 1
  fi
done

echo "✅ Pre-commit checks passed."
