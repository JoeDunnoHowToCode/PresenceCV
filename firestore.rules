rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // 全域預設阻擋所有未經授權的存取
    match /{document=**} {
      allow read, write: if false;
    }

    // AI 掃描次數限制記錄 (新功能開通)
    // 額度由 Server-side Admin SDK 處理，前端嚴禁修改
    match /user_limits/{userId} {
      allow get: if request.auth != null && request.auth.uid == userId;
      allow write, delete, list: if false;
    }

    // 使用者主體設定存取
    match /users/{userId} {
      allow get: if request.auth != null && request.auth.uid == userId;
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null && request.auth.uid == userId;
      allow delete: if false;
      allow list: if false;
      
      match /userState/{docId} {
        allow read: if request.auth != null && request.auth.uid == userId;
        // 限制每個帳號最多只能擁有 3 份履歷
        // 若本身已經超過 3 份，允許修改舊資料（長度 <= 原長度），但不允許新增
        // 管理員 (admins/{userId} 存在) 則不受此限制
        allow write: if request.auth != null && request.auth.uid == userId
          && (
            !("profiles" in request.resource.data) ||
            request.resource.data.profiles.size() <= 3 ||
            (resource != null && "profiles" in resource.data && request.resource.data.profiles.size() <= resource.data.profiles.size()) ||
            exists(/databases/$(database)/documents/admins/$(request.auth.uid))
          );
      }
    }

    // 快照分享連結 (需要登入建立，任何人憑 ID 可讀，不可修改)
    match /sharedResumes/{resumeId} {
      allow create: if request.auth != null 
        && request.resource.data.keys().hasAll(['profile', 'blocks', 'blockOrder', 'createdAt'])
        && request.resource.data.keys().hasOnly(['profile', 'blocks', 'blockOrder', 'createdAt', 'themeColor', 'enableAnimation']);
      allow get: if true;
      allow list: if false;
      allow update, delete: if false;
    }

    // Live 即時同步連結 (權限與擁有者綁定)
    match /liveResumes/{resumeId} {
      allow create: if request.auth != null
        && request.resource.data.keys().hasAll(['profile', 'blocks', 'blockOrder'])
        && request.resource.data.ownerUid == request.auth.uid;
      allow get: if true;
      allow list: if false;
      allow update: if request.auth != null && (
        (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['ownerUid'])) &&
        (
          (resource.data.ownerUid == request.auth.uid) ||
          (!("ownerUid" in resource.data) && request.resource.data.updateToken == resource.data.updateToken)
        )
      );
      allow delete: if false;
    }
  }
}
